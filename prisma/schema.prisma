generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  businessName String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients          Client[]
  invoices         Invoice[]
  expenses         Expense[]
  teamMembers      TeamMember[]
  teamPayments     TeamPayment[]
  businessSettings BusinessSettings?
  notifications    Notification[]
  proposals        Proposal[]
}

model BusinessSettings {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName        String?
  logoUrl             String?
  address             String?
  phone               String?
  email               String?
  website             String?
  taxNumber           String?
  paymentInstructions String?
  footerNote          String?
  defaultTaxRate      Float    @default(0)
  defaultPaymentTerms Int      @default(30)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("business_settings")
}

model Client {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  email          String?
  phone          String?
  company        String?
  address        String?
  notes          String?
  portalToken    String?   @unique @map("portal_token")
  portalLastSeen DateTime? @map("portal_last_seen")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoices        Invoice[]
  portalMessages  PortalMessage[]
  paymentClaims   PortalPaymentClaim[]
  disputes        InvoiceDispute[]
  proposals       Proposal[]
}

model Invoice {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)

  number           String
  title            String?
  status           InvoiceStatus    @default(DRAFT)
  paymentStructure PaymentStructure @default(FULL)
  issueDate        DateTime         @default(now())
  dueDate          DateTime
  notes            String?

  subtotal         Float            @default(0)
  discount         Float            @default(0)
  tax              Float            @default(0)
  total            Float            @default(0)

  clientApproved   Boolean          @default(false) @map("client_approved")
  clientApprovedAt DateTime?        @map("client_approved_at")

  isRetainer       Boolean          @default(false) @map("is_retainer")
  retainerHours    Float?           @map("retainer_hours")

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  items            InvoiceItem[]
  payments         Payment[]
  phases           InvoicePhase[]
  portalMessages   PortalMessage[]
  paymentClaims    PortalPaymentClaim[]
  deliverables     Deliverable[]
  disputes         InvoiceDispute[]
  retainerEntries  RetainerEntry[]
}

model InvoicePhase {
  id         String     @id @default(uuid())
  invoiceId  String
  invoice    Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  name       String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  status     PhaseStatus @default(UNPAID)
  workStatus WorkStatus  @default(PENDING) @map("work_status")
  notes      String?
  sortOrder  Int         @default(0)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  paymentClaims PortalPaymentClaim[]
  deliverables  Deliverable[]

  @@map("invoice_phases")
}

model Deliverable {
  id          String       @id @default(uuid())
  invoiceId   String
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  phaseId     String?
  phase       InvoicePhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  name        String
  description String?
  fileUrl     String
  fileType    String?

  createdAt   DateTime     @default(now())

  @@map("deliverables")
}

model InvoiceDispute {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  note      String
  resolved  Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("invoice_disputes")
}

model Proposal {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title       String
  description String?
  items       Json           @default("[]")
  total       Float          @default(0)
  status      ProposalStatus @default(DRAFT)
  clientNote  String?
  validUntil  DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("proposals")
}

model RetainerEntry {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  hours       Float?
  amount      Float    @default(0)
  date        DateTime

  createdAt   DateTime @default(now())

  @@map("retainer_entries")
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime
  method    String?
  notes     String?
  createdAt DateTime @default(now())
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float
  unitPrice   Float
  total       Float
}

model Expense {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  description String
  amount      Float
  category    ExpenseCategory
  date        DateTime
  project     String?
  isRecurring Boolean         @default(false)
  notes       String?
  receipt     String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  role      String?
  email     String?
  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments  TeamPayment[]
}

model TeamPayment {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberId    String?
  member      TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  name        String
  role        String?
  amount      Float
  date        DateTime
  description String?
  status      PaymentStatus @default(PAID)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalPaymentClaim {
  id         String        @id @default(uuid())
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  phaseId    String?
  phase      InvoicePhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  amount     Float
  receiptUrl String?
  note       String?
  status     ClaimStatus @default(PENDING)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("portal_payment_claims")
}

model PortalMessage {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId  String?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  content    String
  fromClient Boolean  @default(true)
  read       Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@map("portal_messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("payment")
  message   String
  invoiceId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStructure {
  FULL
  PARTIAL
  SCHEDULED
}

enum PhaseStatus {
  UNPAID
  PAID
}

enum WorkStatus {
  PENDING
  IN_PROGRESS
  UNDER_REVIEW
  DELIVERED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  CHANGES_REQUESTED
  REJECTED
}

enum ExpenseCategory {
  SOFTWARE
  MARKETING
  SALARIES
  RENT
  EQUIPMENT
  TRAVEL
  UTILITIES
  TAXES
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
  CANCELLED
}

enum ClaimStatus {
  PENDING
  CONFIRMED
  REJECTED
}
